generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int         @id @default(autoincrement())
  username  String      @unique
  password  String
  name      String
  gender    Gender
  birthDate String
  createdAt DateTime    @default(now())
  scraps    scraps[]
  timelines timelines[]

  @@map("users")
}

model articles {
  id          Int      @id @default(autoincrement())
  keyword     String
  title       String
  publishedAt DateTime
  source      String
  content     String?
  imageUrl    String?
  url         String
  scraps      scraps[]
}

model scraps {
  id             Int              @id @default(autoincrement())
  userId         Int
  articleId      Int
  createdAt      DateTime         @default(now())
  articles       articles         @relation(fields: [articleId], references: [id], onDelete: Cascade)
  users          User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  timeline_items timeline_items[]

  @@unique([userId, articleId])
}

model timeline_items {
  id         Int       @id @default(autoincrement())
  position   Int
  createdAt  DateTime  @default(now())
  timelineId Int
  scrapId    Int
  scraps     scraps    @relation(fields: [scrapId], references: [id], onDelete: Cascade)
  timelines  timelines @relation(fields: [timelineId], references: [id], onDelete: Cascade)

  @@unique([timelineId, scrapId])
}

model timelines {
  id             Int              @id @default(autoincrement())
  name           String
  createdAt      DateTime         @default(now())
  updatedAt      DateTime
  userId         Int
  timeline_items timeline_items[]
  users          User             @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum Gender {
  m
  f
  n
}
