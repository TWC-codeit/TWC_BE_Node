            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string",
                    "example": "수정된 타임라인 이름"
                  },
                  "items": {
                    "type": "array",
                    "description": "타임라인에 포함된 아이템들",
