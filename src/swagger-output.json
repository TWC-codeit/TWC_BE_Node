    "/api/scraps/": {
      "get": {
        "tags": ["스크랩"],
        "summary": "유저의 스크랩 목록 조회",
        "description": "",
        "parameters": [
          {
            "name": "authorization",
            "in": "header",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          },
          "400": {
            "description": "Bad Request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      },
      "post": {
        "tags": ["스크랩"],
        "summary": "유저의 스크랩 생성",
        "description": "Request body 2가지 - Example 1(articleId), Example 2(redisKey, index)",
        "parameters": [
          {
            "name": "authorization",
            "in": "header",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "201": {
            "description": "Created"
          },
          "400": {
            "description": "Bad Request"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "oneOf": [
                  {
                    "type": "object",
                    "properties": {
                      "redisKey": {
                        "type": "string",
                        "example": "keyword:{키워드명}:articles"
                      },
                      "index": {
                        "type": "integer",
                        "example": 1
                      }
                    }
                  },
                  {
                    "type": "object",
                    "properties": {
                      "articleId": {
                        "type": "integer",
                        "example": "3"
                      }
                    }
                  }
                ]
              },
              "examples": {
                "Example 1 (redisKey & index)": {
                  "value": {
                    "redisKey": "keyword:수출:articles",
                    "index": 0
                  }
                },
                "Example 2 (articleId)": {
                  "value": {
                    "articleId": 15
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/scraps/{scrapId}": {
